            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"price\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          },
          "response": []
        },
        {
